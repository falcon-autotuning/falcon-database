prefix=${pcfiledir}/../..
exec_prefix=${prefix}
libdir=${exec_prefix}/lib
includedir=${prefix}/../include

Name: libecpg_compat
Description: PostgreSQL libecpg_compat library
URL: https://www.postgresql.org/
Version: 16.9
Requires: 
Requires.private: libecpg, libpgtypes
Cflags: "-I${includedir}"
Libs: "-L${libdir}" -lecpg_compat
Libs.private: "-L${prefix}/lib" "-L${prefix}/lib/manual-link" "-L${prefix}/lib/pkgconfig/../../lib" -lecpg -lpgcommon -lpgport -lpq -lm

