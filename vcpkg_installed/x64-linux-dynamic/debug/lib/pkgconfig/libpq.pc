prefix=${pcfiledir}/../..
exec_prefix=${prefix}
libdir=${exec_prefix}/lib
includedir=${prefix}/../include

Name: libpq
Description: PostgreSQL libpq library
URL: https://www.postgresql.org/
Version: 16.9
Requires: 
Requires.private: libssl, libcrypto
Cflags: "-I${includedir}"
Libs: "-L${libdir}" -lpq
Libs.private: "-L${prefix}/lib" "-L${prefix}/lib/manual-link" "-L${prefix}/lib/pkgconfig/../../lib" -lpgcommon -lpgport -lssl -lm

