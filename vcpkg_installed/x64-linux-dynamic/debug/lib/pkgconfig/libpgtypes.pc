prefix=${pcfiledir}/../..
exec_prefix=${prefix}
libdir=${exec_prefix}/lib
includedir=${prefix}/../include

Name: libpgtypes
Description: PostgreSQL libpgtypes library
URL: https://www.postgresql.org/
Version: 16.9
Requires: 
Requires.private: 
Cflags: "-I${includedir}"
Libs: "-L${libdir}" -lpgtypes
Libs.private: "-L${prefix}/lib" "-L${prefix}/lib/manual-link" "-L${prefix}/lib/pkgconfig/../../lib" -lpgcommon -lpgport -lm

