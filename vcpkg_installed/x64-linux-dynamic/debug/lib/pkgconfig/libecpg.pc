prefix=${pcfiledir}/../..
exec_prefix=${prefix}
libdir=${exec_prefix}/lib
includedir=${prefix}/../include

Name: libecpg
Description: PostgreSQL libecpg library
URL: https://www.postgresql.org/
Version: 16.9
Requires: 
Requires.private: libpq, libpgtypes
Cflags: "-I${includedir}"
Libs: "-L${libdir}" -lecpg
Libs.private: "-L${prefix}/lib" "-L${prefix}/lib/manual-link" "-L${prefix}/lib/pkgconfig/../../lib" -lpgcommon -lpgport -lpq -lm

